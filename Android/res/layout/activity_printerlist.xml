<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:id="@+id/parent_layout">

    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="80px" android:id="@+id/title_layout" android:background="@drawable/common_header">
        <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/STR_SELPRINTER_TITLE"
                android:id="@+id/txt_title" android:textColor="#FFFFFF" android:textSize="30px"
                android:gravity="center"/>
        <ImageButton
                android:layout_width="110px"
                android:layout_height="70px"
                android:id="@+id/btn_back" android:layout_marginLeft="14px" android:layout_centerVertical="true"
                android:background="@drawable/common_button" android:src="@drawable/common_goback"
                android:scaleType="centerInside" android:padding="6dp" android:layout_alignParentEnd="false"/>
        <ImageButton
                android:layout_width="70px"
                android:layout_height="70px"
                android:id="@+id/btn_refresh" android:layout_centerVertical="true" android:layout_marginRight="14px"
                android:layout_alignParentRight="true" android:background="@drawable/common_button"
                android:src="@drawable/sale_search" android:padding="8dp" android:scaleType="centerInside"/>
    </RelativeLayout>
    <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent" android:id="@+id/content_layout"
            android:layout_below="@+id/title_layout" android:background="#FFFFFF">
        <ScrollView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:id="@+id/scrollView" android:layout_alignParentTop="true"
                android:layout_above="@+id/control_panel">
            <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" android:id="@+id/list_layout">
            </LinearLayout>
        </ScrollView>
    </RelativeLayout>
</RelativeLayout>