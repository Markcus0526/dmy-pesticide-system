<body>
    <div id="portlet">
        <div class="table-toolbar">
             <div class="table-toolbar">
                    <div class="btn-group" style="display:none;">
                        <a href="#set_dialog" data-toggle="modal" class="btn default" id="addButton"><i class="fa fa-plus"></i> 添加</a>&nbsp;&nbsp;
                    </div>
		            <div class="btn-group pull-right">
                         <button onclick="add_user();" class="btn custom_button">新增用户</button>&nbsp;&nbsp;
                    </div>                  

			 </div>
        </div>


        <div class="portlet-body" style="display: block;">
            <div id="table-responsive">
                <table class="table table-striped  table-advance table-bordered table-hover" id="tbllist">
                    <thead>
                        <tr>
                            <th style="width:70px; text-align: center;">编号</th>
                            <th style=" text-align: center;">地区</th>
                            <th style=" text-align: center;">单位名称</th>
                            <th style=" text-align: center;">姓名</th>
                            <th style=" text-align: center;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
            <div id="hiddenpart" style="display:none">
                <input type="text" id="roleinfo" name="roleinfo"/>
            </div>
        </div>
    </div>

    <!-- DIALOG PART-->
    <div id="set_dialog" class="modal fade" tabindex="-1" data-width="620px" data-height="500px" data-backdrop="static">
        <form action="#" id="submit_form" class="form-horizontal form-validate">
            <!--<div class="modal-dialog" >-->
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"></button>
                    <h4 class="modal-title">新增用户</h4>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12">
                            <table class="consider-table">
                                <tr>
                                    <td class="label-td">
                                        <b>
                                            用户名：
                                        </b>
                                    </td>
                                    <td style="width: 300px;vertical-align:top;">
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="text" id="userid" name="userid" class="form-control"  />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                               
                                <tr>
                                    <td class="label-td" style="width:200px">
                                        <b>初始密码：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="password" name="password" id="password" class="form-control"  />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-td" style="width:200px">
                                        <b>姓名：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="text" name="username" id="username" class="form-control"  />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-td">
                                        <b>地区：
                                        </b>
                                    </td>
                                </tr>
                                <tr id="city_part">
                                    <td class="label-td">
                                        <b>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;盟\市：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <select size="1" name="city" id="city" class="form-control adjust-left" style="width: 200px;">
                                                    @{
                                                        List<tbl_region> city_regions = ViewBag.region;
                                                        for (int i = 0; i < city_regions.Count; i++)
                                                        {
                                                            tbl_region item = city_regions.ElementAt(i);
                                                            <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <tr id="district_part">
                                    <td class="label-td">
                                        <b>&nbsp;&nbsp;旗\县：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <select size="1" name="district" id="district" class="form-control adjust-left" style="width: 200px;">
                                                    @{
                                                        List<tbl_region> district_regions = ViewBag.region;
                                                        for (int i = 0; i < district_regions.Count; i++)
                                                        {
                                                            tbl_region item = district_regions.ElementAt(i);
                                                            <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-td">
                                        <b>单位名称：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="text" name="unit_name" id="unit_name" class="form-control" />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="label-td">
                                        <b>联系方式：
                                        </b>
                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="text" name="connect" class="form-control" id="connect" value=""  />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                
                            </table>
                        </div>
                    </div>
                    <div class="modal-hidden" style="display: none">
                        <a id="real_act" class="btn white" data-target="#set_dialog" data-toggle="modal"></a>
                        <input type="text" name="uid" id="uid" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="submit" class="btn custom_button" onclick="submit_user()" >保存</button>
                    <button type="button" data-dismiss="modal" class="btn custom_button" id="cancelSubmit">取消</button>
                </div>
            </div>
            <input type="hidden" name="pass" id="pass" value="1">
            <input type="hidden" name="aid" id="aid" value="">
            <input type="hidden" name="uid" id="uuid" />
            <!--</div>-->
        </form>
    </div>

    <div id="modalDelete" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel3" aria-hidden="true" style="top: 120px;" data-backdrop="static">
        <form action="#" id="submit_form_delete" class="form-horizontal form-validate">
            <div class="modal-content">
                <!--<div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"></button>
                    您确定要删除批量经销商吗?
                </div>-->

                <div class="modal-body">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"></button>
                    您确定要删除用户吗?
                </div>

                <input type="hidden" name="id" id="del_id" value="" />

                <div class="modal-footer">
                    <button class="btn custom_button" data-dismiss="modal" aria-hidden="true">取消</button>
                    <button class="btn custom_button" data-dismiss="modal" onclick="deleteUser();">确定</button>
                </div>
            </div>
        </form>
    </div>

