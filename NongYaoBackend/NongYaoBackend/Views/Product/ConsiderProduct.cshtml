                    oSettings = oTable.fnSettings();

                    //Retrieve the new data with $.getJSON. You could use it ajax too
                    var name = $("#search_word").val();
                    var pass = $("#search_pass").val();
                    oSettings.sAjaxSource = "@Url.Content("~/Product/RetrieveCatalogList")" + "?pass=" + pass + "&search=" + name;

                    $.getJSON(oSettings.sAjaxSource, null, function (json) {
                        //oTable.fnClearTable(this);

                        for (var i = 0; i < json.aaData.length; i++) {
                            oTable.oApi._fnAddData(oSettings, json.aaData[i]);
                        }

                        oSettings.aiDisplay = oSettings.aiDisplayMaster.slice();
                        oTable.fnDraw();
                    });
