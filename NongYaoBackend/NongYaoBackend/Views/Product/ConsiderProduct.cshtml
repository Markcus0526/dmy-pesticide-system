                    function loadBarcode(making) {
                        var precode = $("#register_id").val();
                        var barcode = $("#barcode").val();
                        if (making == 1 || (making == 0 && barcode.length > 0)) {
                            $.ajax({
                                url: "@Url.Content("~/Product/GetBarcode")",
                                data: {
                                    "precode": precode,
                                    "barcode": barcode,
                                    "making": making
                                },
                                type: "post",
                                success: function (data) {
                                    if (data != null) {
                                        $("#barcode").val(data.bin);
                                        $("#barcodeImage").html(data.image);
                                    } else {
                                        $("#barcode").val("");
                                        $("#barcodeImage").html("");
                                    }
                                }
                            });

                            //$("#barcodeImage").html('<img id="Image1" src="@Url.Content("~/Views/Shared/GetCode.ashx?m=0&h=60&vCode=")' + barcode + '" alt="' + barcode + '"/>');
                        } else {
                            $("#barcodeImage").html("");
                        }
                    }

                    function makeBarcode() {
                        var precode = $("#register_id").val();
                        if (precode.length > 0 /*&& !isNaN(precode) && precode.length >= 10 && precode.length <= 12*/) {
                            $("#register_id").parent().removeClass("has-error").addClass("has-success");
                            loadBarcode(1);
                        } else {
                            $("#register_id").parent().removeClass("has-success").addClass("has-error");
                        }
                    }

