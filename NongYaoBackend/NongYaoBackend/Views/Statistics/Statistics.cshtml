                                },
                                dataType: "json"
                            }
                        },
                        sort: {
                        }
                    },
                    legend: {
                        position: "bottom"
                    },
                    seriesDefaults: {
                        type: "column",
                        stack: true,
                    },
                    series: [{
                        field: "saleCount",
                        labels: {
                            visible: true,
                            format: "{0}"
                        },
                        name: "销售数量"
                    }, {
                        field: "remainCount",
                        color: "blue",
