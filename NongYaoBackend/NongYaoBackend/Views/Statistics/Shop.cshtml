@using NongYaoBackend.Models;
@{
    ViewBag.Title = "农药溯源管理云平台";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>统计</title>

    <link href="@Url.Content("~/Content/plugins/select2/select2_metro.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/bootstrap-toastr/toastr.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/data-tables/DT_bootstrap.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/bootstrap-datepicker/css/datepicker.css")" rel="stylesheet" type="text/css"/>

    <link href="@Url.Content("~/Content/plugins/bootstrap-modal/css/bootstrap-modal-bs3patch.css")" rel="stylesheet" type="text/css"/>
    <link href="@Url.Content("~/Content/plugins/bootstrap-modal/css/bootstrap-modal.css")" rel="stylesheet" type="text/css"/>

    <script src="@Url.Content("~/Content/plugins/jquery-1.10.2.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/jquery-migrate-1.2.1.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/jquery-ui/jquery-ui-1.10.3.custom.min.js")" type="text/javascript"></script>

    <script src="@Url.Content("~/Content/plugins/data-tables/jquery.dataTables.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/data-tables/DT_bootstrap.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap/js/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootbox/bootbox.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap-toastr/toastr.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/jquery-validation/dist/jquery.validate.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap-modal/js/bootstrap-modal.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap-modal/js/bootstrap-modalmanager.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap-datepicker/js/bootstrap-datepicker.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/plugins/bootstrap-datepicker/js/locales/bootstrap-datepicker.zh-CN.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/scripts/app.js")" type="text/javascript"></script>

</head>

<body>
    <div id="portlet">
        <div class="table-toolbar">
            <table class="table table-striped">
                <tr>
                    <td style="width: 120px; text-align: right">
                        <b>地区:</b>
                    </td>
                    <td>
                        <select size="1" id="shop_region" name="shop_region" aria-controls="tbllist" onchange="changeShopRegion();" style="width: 120px;">
                            @{
                                if (ViewBag.role == 0)
                                {
                                <option value="0">&nbsp;&nbsp;全部</option>
                                    List<tbl_region> region_info = ViewBag.cityregion;
                                    for (int i = 0; i < region_info.Count; i++)
                                    {
                                        tbl_region item = region_info.ElementAt(i);
                                <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                    }
                                }
                                else if (ViewBag.role == 1)
                                {
                                <option value="@ViewBag.curCityId">&nbsp;&nbsp;全部</option>
                                    List<tbl_region> region_info1 = ViewBag.curDistrictList;
                                    for (int i = 0; i < region_info1.Count; i++)
                                    {
                                        tbl_region item = region_info1.ElementAt(i);
                                <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                    }
                                }
                                else if (ViewBag.role == 2)
                                {
                                <option value ="@ViewBag.curDistrictId">&nbsp;&nbsp;@ViewBag.curDistrictName</option>
                                }
                            }

                        </select>
                    </td>
                    <td style="text-align: center">
                        <div>
                            <b>经销商:</b>
                            <input type="text" id="salesman_pinyin" placeholder="经营许可证代码\拼音简码" style="vertical-align: middle;" />
                            <input type="button" class="btn custom_button" id="search_salesman" onclick="search_salesman();" value="模糊查询" style="vertical-align: middle;" />
                            <select size="1" id="salesman_select" name="salesman_select" onchange="selectSalesman();" style="width: 150px; vertical-align: middle;"></select>
                        </div>
                    </td>
                </tr>

            </table>
            <table class="table table-striped">
                <tr>
                    <td style="width: 80px; text-align: right">
                        <b class="calendar">开始日期:</b>
                    </td>
                    <td style="width: 130px;">
                        <input type=text name="shop_start_date" class="date_input" id="shop_start_date" data-date-format='yyyy-mm-dd' value="@Convert.ToString(ViewBag.Year)-@String.Format("{0:00}", ViewBag.Month)-@String.Format("{0:00}", ViewBag.Day)" style="margin-right: 5px;" onchange="shop_start_date_change();"/>
                    </td>
                    <td style="width: 80px; text-align: right">
                        <b class="calendar">结束日期:</b>
                    </td>
                    <td style="width: 130px;">
                        <input type=text name="shop_end_date" class="date_input" id="shop_end_date" data-date-format='yyyy-mm-dd' value="@String.Format("{0:yyyy-MM-dd}", DateTime.Now)" style="margin-right: 5px;" onchange="shop_end_date_change();" />
                    </td>
                    <td style="width: 50px;">
                        <input type="checkbox" name="level" class="date_input" id="level" style="margin-right: 5px;" value="off" onchange="level_change();" /><b>高毒</b>
                    </td>
                </tr>
            </table>
        </div>

        <div id="table-responsive">
            <table class="table table-striped  table-advance table-bordered table-hover" id="tbllist">
                <thead>
                    <tr>
                        <th style="text-align: center; width: 150px;">经营许可证代码</th>
                        <th style="text-align: center;">地区</th>
                        <th style="text-align: center;">经销商名称</th>
                        <th style="text-align: center;">法人</th>
                        <th style="text-align: center;">联系方式</th>
                        <th style="text-align: center;">库存总数量</th>
                        <th style="text-align: center;">销售总数量</th>
                        <th style="text-align: center; width: 100px;">操作</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
        <div id="control_button" style="text-align: right; padding-top: 20px;">
            <input type="button" id="shop_exl" class="btn custom_button" onclick="export_excel();" value="导出EXL" />
            <input type="button" id="shop_print" class="btn custom_button" onclick="printShop()" value="打印" />
        </div>
    </div>
    <div id="modalDelete" class="modal fade" tabindex="-1" data-width="300px" data-height="80px" style="top: 120px;" data-backdrop="static">
        <form action="#" id="submit_form_delete" class="form-horizontal form-validate">
            <div class="modal-content">
                <div class="modal-body">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"></button>
                    您确定要删除经销商吗?
                </div>

                <input type="hidden" name="id" id="del_id" value="" />

                <div class="modal-footer">
                    <button class="btn custom_button" data-dismiss="modal" onclick="submitform_delete();">确定</button>
                    <button class="btn custom_button" data-dismiss="modal" aria-hidden="true">取消</button>
                </div>
            </div>
        </form>
    </div>
    <div id="modalMap" class="modal fade" tabindex="-1" data-width="800px" data-height="500px" style="top: 400px;" data-backdrop="static">
        <form action="#" id="submit_form_delete" class="form-horizontal form-validate">
            <div class="modal-content">
                <div class="modal-body">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true"></button>
                    <div class="col-md-4" id="allmap" style="height: 300px; width: 700px; overflow: hidden; margin-top: 50px; margin-left: 50px; text-align: center;">
                    </div>

                    <input type="hidden" name="id" id="del_id" value="" />

                    <div class="modal-footer">
                        <button class="btn custom_button" data-dismiss="modal" style="margin-top: 40px;">确定</button>
                        <button class="btn custom_button" data-dismiss="modal" style="margin-top: 40px;" aria-hidden="true">取消</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
    <div id="print_page_shop" style="display: none; font-size: 16px;">
        <p style="text-align: center;"><font style="font-size: 24px;"><b>经销商统计</b></font></p>
        <br />
        <span style="float: left; margin-left: 15px;">日期:<span id="print_shop_date"></span></span>
        <span style="float: right; margin-right: 15px;">打印日期:@DateTime.Now</span><br />
        <table class="table_view" border="1">
            <thead>
                <tr>
                    <th style="text-align: center; width: 150px;">经营许可证代码</th>
                    <th style="text-align: center;">地区</th>
                    <th style="text-align: center;">经销商名称</th>
                    <th style="text-align: center;">法人</th>
                    <th style="text-align: center;">联系方式</th>
                    <th style="text-align: center;">库存总数量</th>
                    <th style="text-align: center;">销售总数量</th>
                </tr>
            </thead>
            <tbody id="print_shop_body" style="background: white; border: 0px;"></tbody>
        </table>
    </div>
    <form action="@Url.Content("~/Statistics/ExportShopData")" method="post" id="submit_form_terminal" class="form-horizontal form-validate" target="_blank">
    </form>
    <script>
        //var map = new BMap.Map("allmap");

        var oTable;
        var handleDataTable = function () {
            if (!jQuery().dataTable) {
                return;
            }

            // begin first table
            oTable = $('#tbllist').dataTable({
                "bServerSide": true,
                "bProcessing": true,
                "sAjaxSource": "@Url.Content("~/Statistics/GetShopTableData")",
                        "oLanguage": {
                            "sUrl": "@Url.Content("~/Content/i18n/dataTables.chinese.txt")"
                        },
                        "aoColumns": [
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false },
                            { "bSortable": false }
                        ],
                        "aLengthMenu": [
                            [1, 10, 20, 50, -1],
                            [1, 10, 20, 50, "All"] // change per page values here
                        ],
                        // set the initial value
                        "iDisplayLength": 10,
                        "bFilter": false,
                        "bLengthChange": false,
                        "sPaginationType": "bootstrap",
                        "aoColumnDefs": [
                            {
                                aTargets: [5],    // Column number which needs to be modified
                                sClass: 'center'    // Optional - class to be applied to this table cell
                            },
                            {
                                aTargets: [6],    // Column number which needs to be modified
                                sClass: 'center'    // Optional - class to be applied to this table cell
                            },
                            {
                                aTargets: [7],    // Column number which needs to be modified
                                fnRender: function (o, v) {   // o, v contains the object and value for the column
                                    var rhtml = "<a href='#modalMap' data-toggle='modal' onclick='init_edit_dialog(" + o.aData[7] + "," + o.aData[8] + "," + o.aData[9] + ");'><img src='" + "../../Content/img/setting.png" + "' style='width:20px; height:20px;'/></a>&nbsp;&nbsp;" +
                                        '<a href="#modalDelete" data-toggle="modal" onclick="' +
                                        '$(\'#del_id\').val(\'' + o.aData[7] + '\');' +
                                        '">' +
                                        '<img src="../../Content/img/thresh.png" style="width:20px; height:20px;"/>' +
                                        '</a>';
                                    return rhtml;
                                },
                                sClass: 'center'    // Optional - class to be applied to this table cell
                            }
                        ]
                    });
                }
                function init_edit_dialog(id, lon, lat) {
                    /*
                    var point = new BMap.Point(lon, lat);
                    map.centerAndZoom(point, 15);
                    map.enableScrollWheelZoom();
                    map.clearOverlays();
                    var markerpoint = new BMap.Point(lon + 0.024, lat - 0.008);
                    map.addOverlay(new BMap.Marker(markerpoint));
                    */
                }
                function refreshTable() {
                    oSettings = oTable.fnSettings();

                    //Retrieve the new data with $.getJSON. You could use it ajax too
                    $.getJSON(oSettings.sAjaxSource, null, function (json) {
                        oTable.fnClearTable(this);

                        for (var i = 0; i < json.aaData.length; i++) {
                            oTable.oApi._fnAddData(oSettings, json.aaData[i]);
                        }

                        oSettings.aiDisplay = oSettings.aiDisplayMaster.slice();
                        oTable.fnDraw();
                    });
                }
                function changeShopRegion() {
                    $.ajax({
                        url: "@Url.Content("~/Statistics/changeShopRegion/")",
                        data: {
                            regionid: $("#shop_region").val()
                        },
                        success: function (data) {
                            $("#salesman_pinyin").val("");
                            $("#salesman_select").html("");
                            refreshTable();
                        }
                    });
                }

                function search_salesman() {
                    if ($("#salesman_pinyin").val() == "") {
                        $("#salesman_select").html("");
                        changeShopRegion();
                    }
                    else {
                        $.ajax({
                            url: "@Url.Content("~/Statistics/searchSalesman/")",
                            data: {
                                basepinyin: $("#salesman_pinyin").val()
                            },
                            success: function (data) {
                                var salesman = data.salesmanlist;
                                var html = "";
                                for (var i = 0; i < salesman.length; i++) {
                                    html += "<option value=\"" + salesman[i].uid + "\">&nbsp;&nbsp;" + salesman[i].name + "</option>";
                                }
                                $("#salesman_select").html(html);
                                selectSalesman();
                            }
                        });
                    }
                }

                function selectSalesman() {
                    $.ajax({
                        url: "@Url.Content("~/Statistics/changeSalesman/")",
                        data: {
                            shopid: $("#salesman_select").val()
                        },
                        success: function (data) {
                            refreshTable();
                        }
                    });
                }

                function shop_start_date_change() {
                    if ($("#shop_start_date").val() > $("#shop_end_date").val()) {
                        toastr.options = {
                            "closeButton": false,
                            "debug": true,
                            "positionClass": "toast-top-center",
                            "onclick": null,
                            "showDuration": "3",
                            "hideDuration": "3",
                            "timeOut": "2500",
                            "extendedTimeOut": "1000",
                            "showEasing": "swing",
                            "hideEasing": "linear",
                            "showMethod": "fadeIn",
                            "hideMethod": "fadeOut"
                        };
                        toastr["error"]("日期错误，开始日期要提前结束日期", "温馨敬告");
                    }

                    $.ajax({
                        url: "@Url.Content("~/Statistics/shopStartDateChange/")",
                        data: {
                            startDate: $("#shop_start_date").val()
                        },
                        success: function (data) {
                            refreshTable();
                        }
                    });
                }
                function shop_end_date_change() {
                    if ($("#shop_start_date").val() > $("#shop_end_date").val()) {
                        toastr.options = {
                            "closeButton": false,
                            "debug": true,
                            "positionClass": "toast-top-center",
                            "onclick": null,
                            "showDuration": "3",
                            "hideDuration": "3",
                            "timeOut": "2500",
                            "extendedTimeOut": "1000",
                            "showEasing": "swing",
                            "hideEasing": "linear",
                            "showMethod": "fadeIn",
                            "hideMethod": "fadeOut"
                        };
                        toastr["error"]("日期错误，开始日期要提前结束日期", "温馨敬告");
                    }

                    $.ajax({
                        url: "@Url.Content("~/Statistics/shopEndDateChange/")",
                        data: {
                            endDate: $("#shop_end_date").val()
                        },
                        success: function (data) {
                            refreshTable();
                        }
                    });
                }

                function submitform_delete() {
                    $.ajax({
                        async: false,
                        type: "POST",
                        url: "@Url.Content("~/Statistics/DeleteShop")",
                        dataType: "json",
                        data: $('#submit_form_delete').serialize(),
                        success: function (data) {
                            if (data == true) {
                                toastr.options = {
                                    "closeButton": false,
                                    "debug": true,
                                    "positionClass": "toast-top-center",
                                    "onclick": null,
                                    "showDuration": "3",
                                    "hideDuration": "3",
                                    "timeOut": "1500",
                                    "extendedTimeOut": "1000",
                                    "showEasing": "swing",
                                    "hideEasing": "linear",
                                    "showMethod": "fadeIn",
                                    "hideMethod": "fadeOut"
                                };
                                toastr["success"]("删除成功!", "恭喜您");
                                refreshTable();
                            } else {
                                toastr.options = {
                                    "closeButton": false,
                                    "debug": true,
                                    "positionClass": "toast-top-center",
                                    "onclick": null,
                                    "showDuration": "3",
                                    "hideDuration": "3",
                                    "timeOut": "1500",
                                    "extendedTimeOut": "1000",
                                    "showEasing": "swing",
                                    "hideEasing": "linear",
                                    "showMethod": "fadeIn",
                                    "hideMethod": "fadeOut"
                                };
                                toastr["error"](data.error, "温馨敬告");

                            }
                        },
                        error: function (data) {
                            alert("Error: " + data.status);
                            $('.loading-btn').button('reset');
                        }
                    });
                }
                function level_change() {
                    if ($("#level").val() == "on")
                        $("#level").val("off");
                    else
                        $("#level").val("on");

                    $.ajax({
                        url: "@Url.Content("~/Statistics/changeSalesmanLevel/")",
                        data: {
                            lev_value: $("#level").val()
                        },
                        success: function (data) {
                            refreshTable();
                        }
                    });

                }
                $(document).ready(function () {
                    $("#shop_start_date").datepicker({
                        todayBtn: true
                    });
                    $("#shop_end_date").datepicker({
                        todayBtn: true
                    });

                    handleDataTable();
                });
    </script>
    <script type="text/javascript">
        function printShop() {
            if ($("#tbllist tbody").find("tr") == null) {
                toastr.options = {
                    "closeButton": false,
                    "debug": true,
                    "positionClass": "toast-top-center",
                    "onclick": null,
                    "showDuration": "3",
                    "hideDuration": "3",
                    "timeOut": "1500",
                    "extendedTimeOut": "1000",
                    "showEasing": "swing",
                    "hideEasing": "linear",
                    "showMethod": "fadeIn",
                    "hideMethod": "fadeOut"
                };
                toastr["error"]("", "没有资料！");

                return;
            }

            $("#print_shop_date").html($("#shop_start_date").val() + "~" + $("#shop_end_date").val());

            var strHtml = ""
            $.each($("#tbllist tbody tr"), function () {
                var tds = $(this).find("td");
                strHtml += "<tr>";
                for (var i = 0; i < 7; i++)
                    strHtml += "<td>" + $(tds[i]).html() + "</td>";
                strHtml += "</tr>";
            });

            $("#print_shop_body").html(strHtml);

            pageprint();
        }
        function beforePrint() {
        }
        function afterPrint() {
            $("#header").css("display", "block");
            $("#portlet").css("display", "block");
            $(".ui-tabs-nav").css("display", "block");
            $(".headerback").css("display", "block");
            $("#print_page_shop").css("display", "none");
        }
        function pageprint() {
            window.onbeforeprint = beforePrint;
            window.onafterprint = afterPrint;
            $("#header").css("display", "none");
            $("#portlet").css("display", "none");
            $(".ui-tabs-nav").css("display", "none");
            $(".headerback").css("display", "none");
            $("#print_page_shop").css("display", "block");
            window.print();
            $("#header").css("display", "block");
            $("#portlet").css("display", "block");
            $(".ui-tabs-nav").css("display", "block");
            $(".headerback").css("display", "block");
            $("#print_page_shop").css("display", "none");
        }
    </script>
    <script type="text/javascript">
        function export_excel() {
            $("#submit_form_terminal").submit();
        }
    </script>
</body>
</html>
