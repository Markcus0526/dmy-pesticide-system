                                    </td>
                                    <td>
                                        <div class="form-group">
                                            <div class="col-md-4">
                                                <input type="text" name="notice" id="notice" class="form-control" />
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="modal-hidden" style="display: none">
                        <a id="real_act" class="btn white" data-target="#set_dialog" data-toggle="modal"></a>
                    </div>
                </div>
                <div class="modal-footer">
                    @*<button type="button" data-dismiss="modal" class="btn">通过</button>
						<button type="button" data-dismiss="modal" class="btn">末通过</button>
						<button type="button" class="btn red" onclick="salesman_submit();">关闭</button>*@

                    <button type="button" class="btn custom_button" onclick="pass_catalog()" id="passSubmit">通过</button>
