@using NongYaoBackend.Models;
@using NongYaoBackend.Models.Library;

@{
    ViewBag.Title = "农药溯源管理云平台";
}

<!DOCTYPE html>
<html>
<head>
    <title></title>
    <link href="@Url.Content("~/Content/plugins/select2/select2_metro.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/bootstrap-toastr/toastr.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/data-tables/DT_bootstrap.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/plugins/bootstrap-switch/static/stylesheets/bootstrap-switch-metro.css")" rel="stylesheet" type="text/css"/>
    <link href="@Url.Content("~/Content/plugins/bootstrap-datepicker/css/datepicker.css")" rel="stylesheet" type="text/css"/>
    <link href="@Url.Content("~/Content/plugins/bootstrap-modal/css/bootstrap-modal-bs3patch.css")" rel="stylesheet" type="text/css"/>
    <link href="@Url.Content("~/Content/plugins/bootstrap-modal/css/bootstrap-modal.css")" rel="stylesheet" type="text/css"/>

    @*<link href="@Url.Content("~/Content/plugins/Kendo_jQuery/source/styles/kendo.common.css")" rel="stylesheet" type="text/css" />
        <link href="@Url.Content("~/Content/plugins/Kendo_jQuery/source/styles/kendo.kendo.css")" rel="stylesheet" type="text/css" />*@
</head>

<body>
    <div id="portlet">
        <div class="table-toolbar">
            <table class="table table-striped">
                <tr>
                    <td>
                        <b>地区选择:&nbsp&nbsp</b>
                        <select size="1" id="country" name="country">
                            @{
                                if(ViewBag.role == 0)   
                                {
                                    <option value="0">&nbsp;&nbsp;全部</option>
                                    List<tbl_region> region_info = ViewBag.cityregion;
                                    for (int i = 0; i < region_info.Count; i++)
                                    {
                                        tbl_region item = region_info.ElementAt(i);
                                        <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                    }
                                }
                                else if (ViewBag.role == 1)
                                {
                                    <option value="@ViewBag.curCityId">&nbsp;&nbsp;全部</option>
                                    List<tbl_region> region_info1 = ViewBag.curDistrictList;
                                    for (int i = 0; i < region_info1.Count; i++)
                                    {
                                        tbl_region item = region_info1.ElementAt(i);
                                        <option value="@item.id">&nbsp;&nbsp;@item.name</option>
                                    }
                                }
                                else if (ViewBag.role == 2)
                                {
                                    <option value ="@ViewBag.curDistrictId">&nbsp;&nbsp;@ViewBag.curDistrictName</option>
                                }
                            }
                        </select>
                    </td>
                    <td>
                        <b>经销商名称:&nbsp&nbsp</b><input type="text" id="search_word" name="search_word" placeholder="请输入经销商名称">
                    </td>
                    <td>
                        <b>审核状态:&nbsp&nbsp</b>
                        <select size="1" id="state" name="state">
                            <option value="3">全部</option>
                            <option value="1">通过</option>
                            <option value="2">未通过</option>
                            <option value="0">未审核</option>
                        </select>
                    </td>
                    <td style="text-align: right">
                        <button class="btn custom_button" onclick="search_start();">
                            搜索
                        </button>
                        <button class="btn custom_button" onclick="clear_search();">
                            清空条件
                        </button>
                    </td>
                </tr>
            </table>
        </div>


        <div class="portlet-body" style="display: block;">
            <div id="table-responsive">
                <table class="table table-striped  table-advance table-bordered table-hover" id="tbllist">
                    <thead>
                        <tr>
                            <th style="width: 85px; text-align: center;">编号</th>
                            <th style="width: 200px; text-align: center;">经销商名称</th>
                            <th style="text-align: center;">地区</th>
                            <th style="text-align: center;">地址</th>
                            <th style="width: 150px; text-align: center;">联系人</th>
                            <th style="width: 85px; text-align: center;">是否高毒</th>
                            <th style="width: 85px; text-align: center;">审核状态</th>
                            <th style="width: 70px; text-align: center;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- DIALOG PART-->
